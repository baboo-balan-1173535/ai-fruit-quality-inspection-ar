# Copy this file to ".env" and fill in your own values.
# The real .env is gitignored and must never be committed.

# Anthropic API key for Claude vision analysis (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL connection string for the kiwi_sorter database
PG_CONNECTION=postgresql://postgres:YOUR_PASSWORD@localhost:5432/kiwi_sorter

# Camera index — change if index 0 is taken by another app.
# Run camera_test.py to find the correct index for your webcam.
CAMERA_INDEX=0

# ── Claude analyser tuning (optional) ───────────────────────────────────────
# ANALYSER_MODEL=claude-haiku-4-5
# ANALYSER_MAX_IMAGE_EDGE=512

# ── Security ────────────────────────────────────────────────────────────────
# AR_TOKEN: required in the X-AR-Token header for /detect and /ar-analyze.
# Set to any random string — this is your shared secret with the glasses/mobile.
AR_TOKEN=change-me-to-a-random-string

# ALLOWED_IPS: comma-separated IP allowlist. Empty = allow all LAN devices.
# 127.0.0.1 is always allowed. Example: ALLOWED_IPS=192.168.50.24
ALLOWED_IPS=
